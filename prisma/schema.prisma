// Web Space Station (WSS) — CMS database schema
// Backend foundation only. No frontend coupling.
// Docs: docs/WSS_CHECKPOINT_PHASE_2.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime (Vercel): Supabase Transaction pooler :6543 + ?pgbouncer=true
  url       = env("DATABASE_URL")
  // Migrations / seed locally only — optional on Vercel env
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  AUTHOR
  EDITOR
  MODERATOR
  ADMIN
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

/// How article body/metadata entered the CMS (CMS unification foundation).
enum ArticleContentOrigin {
  EDITORIAL
  RSS
  AI_DRAFT
}

// ─── Models ────────────────────────────────────────────────────────────────--

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  name         String
  createdAt    DateTime  @default(now())

  articles     Article[]

  @@index([role])
  @@map("users")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  colorTheme  String?
  orderIndex  Int       @default(0)

  articles    Article[]

  @@index([orderIndex])
  @@map("categories")
}

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  subtitle    String?
  excerpt     String?
  content     String?       @db.Text
  /// WSS editorial context for RSS articles (general trend framing, not source facts).
  contextNote String?       @db.Text
  coverImage  String?
  status      ArticleStatus @default(DRAFT)
  featured    Boolean       @default(false)
  /// News Engine ranking — higher appears first on homepage.
  score       Int           @default(0)
  readingTime Int?
  /// Editorial / AI tags (max ~5 from RSS enrichment).
  tags        String[]      @default([])

  /// RSS / external publisher name (e.g. NASA, TechCrunch). Null for editorial.
  source      String?
  /// Canonical URL at the publisher — dedupe key for News Engine ingest.
  originalUrl String?       @unique
  /// Provenance for CMS policy (RSS prefill vs manual editorial vs future AI drafts).
  contentOrigin ArticleContentOrigin @default(EDITORIAL)

  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Restrict)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  publishedAt DateTime?

  @@index([status])
  @@index([categoryId])
  @@index([authorId])
  @@index([featured])
  @@index([score])
  @@index([publishedAt])
  @@index([source])
  @@index([contentOrigin])
  @@map("articles")
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String
  createdAt DateTime @default(now())

  @@map("media")
}
