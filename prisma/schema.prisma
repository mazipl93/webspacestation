// Web Space Station (WSS) — CMS database schema
// Backend foundation only. No frontend coupling.
// Docs: docs/WSS_CHECKPOINT_PHASE_2.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime (Vercel): Supabase Transaction pooler :6543 + ?pgbouncer=true
  url       = env("DATABASE_URL")
  // Migrations / seed locally only — optional on Vercel env
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  AUTHOR
  EDITOR
  MODERATOR
  ADMIN
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

/// How article body/metadata entered the CMS (CMS unification foundation).
enum ArticleContentOrigin {
  EDITORIAL
  RSS
  AI_DRAFT
}

// ─── Models ────────────────────────────────────────────────────────────────--

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  name         String
  /// Supabase profile avatar (optional) — for public byline display.
  avatarUrl    String?
  createdAt    DateTime  @default(now())

  articles       Article[]
  bylineArticles Article[] @relation("ArticleBylineUser")

  @@index([role])
  @@map("users")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  colorTheme  String?
  orderIndex  Int       @default(0)

  articles    Article[]

  @@index([orderIndex])
  @@map("categories")
}

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  /// Previous slug after CMS rename — 301 from /aktualnosci/{previousSlug}.
  previousSlug String?
  title       String
  subtitle    String?
  excerpt     String?
  /// Headline on FB share-card image (max ~60 chars in CMS).
  socialCardTitle String?
  /// Hook line under headline on FB share-card (max ~90 chars in CMS).
  socialCardHook  String?
  content     String?       @db.Text
  /// WSS editorial context for RSS articles (general trend framing, not source facts).
  contextNote String?       @db.Text
  coverImage  String?
  /// Caption for cover image (photographer, license, source).
  coverImageCredit String?  @db.Text
  /// Optional byline on public article (e.g. „Jan Kowalski, redakcja WSS”).
  authorByline  String?     @db.Text
  /// Team member shown as author (name + avatar). Manual authorByline when null.
  bylineUserId  String?
  bylineUser    User?         @relation("ArticleBylineUser", fields: [bylineUserId], references: [id], onDelete: SetNull)
  status      ArticleStatus @default(DRAFT)
  featured    Boolean       @default(false)
  /// Homepage hero slider: 0 = off, 1–4 = slide order (ASC on homepage).
  heroPosition Int          @default(0)
  /// Homepage „W centrum uwagi”: 0 = off, 1–4 = slot order (ASC).
  weekTopicPosition Int       @default(0)
  /// Legacy flag — synced: true when weekTopicPosition >= 1.
  weekTopic   Boolean       @default(false)
  /// News Engine ranking — higher appears first on homepage.
  score       Int           @default(0)
  readingTime Int?
  /// Editorial / AI tags (max ~5 from RSS enrichment).
  tags        String[]      @default([])

  /// RSS / external publisher name (e.g. NASA, TechCrunch). Null for editorial.
  source      String?
  /// Canonical URL at the publisher — dedupe key for News Engine ingest.
  originalUrl String?       @unique
  /// Provenance for CMS policy (RSS prefill vs manual editorial vs future AI drafts).
  contentOrigin ArticleContentOrigin @default(EDITORIAL)

  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Restrict)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  publishedAt DateTime?
  /// When status is SCHEDULED — auto-publish at or after this time (scheduler).
  publishAt   DateTime?
  /// Meta Graph API post id after auto-share on first publish (null = not posted yet).
  facebookPostId String?
  facebookPostedAt DateTime?

  @@index([status])
  @@index([categoryId])
  @@index([authorId])
  @@index([featured])
  @@index([heroPosition])
  @@index([weekTopic])
  @@index([weekTopicPosition])
  @@index([score])
  @@index([publishedAt])
  @@index([source])
  @@index([contentOrigin])
  @@index([status, publishAt])
  @@map("articles")
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String
  createdAt DateTime @default(now())

  @@map("media")
}

/// Cached ops snapshots refreshed by `/api/cron/ops-refresh` — user requests read DB only.
model OpsCacheEntry {
  key       String   @id
  payload   Json
  live      Boolean  @default(false)
  fetchedAt DateTime
  updatedAt DateTime @updatedAt

  @@map("ops_cache_entries")
}
