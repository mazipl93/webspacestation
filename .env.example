# Web Space Station — environment variables (template)
# Copy to `.env` locally. On Vercel: Project → Settings → Environment Variables.

# ─── Prisma / PostgreSQL (Supabase) ───────────────────────────────────────────
#
# LOCAL: direct connection (port 5432) is fine.
# VERCEL: use the Transaction pooler (port 6543) so serverless functions do not
# exhaust DB connections. Supabase → Project Settings → Database → Connection string
# → "Transaction pooler" → URI, then append: ?pgbouncer=true
#
# Example (replace [PROJECT], [PASSWORD], [REGION]):
# DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL: direct connection (5432) — for `prisma migrate deploy` and `db:seed`
# from your machine only. Not required in Vercel runtime env.
# DIRECT_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Canonical URL (cache:revalidate, RSS, sitemap). Domyślnie https://webspacestation.pl
# NEXT_PUBLIC_SITE_URL="https://webspacestation.pl"

# Temat tygodnia (homepage) — w CMS dodaj ten tag do wybranych artykułów
# WEEK_TOPIC_TAG=temat-tygodnia
# NEXT_PUBLIC_WEEK_TOPIC_LABEL="Temat tygodnia: Starship"
# NEXT_PUBLIC_WEEK_TOPIC_SUBTITLE="Loty testowe i plany SpaceX na 2026"
# WEEK_TOPIC_LIMIT=5

# ─── Supabase Auth (public — safe in the browser) ─────────────────────────────
# Project Settings → API → Project URL / anon public key
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Server-only: CMS upload okładek → Supabase Storage (Project Settings → API → service_role)
# NIE commituj prawdziwego klucza. Uruchom też supabase/article-covers.sql w SQL Editor.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"

# Optional: seed admin password when running `npm run db:seed`
# SEED_ADMIN_PASSWORD="change-me"

# ─── WSS News Engine (RSS cron) ───────────────────────────────────────────────
# Vercel Cron calls GET /api/cron/rss with: Authorization: Bearer <CRON_SECRET>
# Generate: openssl rand -base64 32
CRON_SECRET="your-cron-secret"

# AI enrichment (OpenAI API — ten sam klucz co na platform.openai.com)
OPENAI_API_KEY="sk-proj-..."
OPENAI_TRANSLATION_MODEL="gpt-5.4-mini"
# RSS_TRANSLATE_PL="false"            # tylko dev — wyłącza AI (szkice pozostają DRAFT)
# RSS_ITEMS_PER_FEED=8                # domyślnie 8 (przyrost); 30 tylko jednorazowy backfill
# RSS_PROCESS_BATCH_SIZE=10             # ile szkiców DRAFT → REVIEW na jedno uruchomienie AI
